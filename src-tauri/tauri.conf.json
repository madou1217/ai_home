{
  "build": {
    "distDir": "../web/dist",
    "devPath": "http://localhost:8000/",
    "beforeDevCommand": "node scripts/desktop/dev-web.js",
    "beforeBuildCommand": "node scripts/desktop/build-web.js"
  },
  "package": {
    "productName": "AI Home",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": "^https?://[^\\s]+$"
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.aih.desktop",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data: blob: aihblob: https://aihblob.localhost; media-src 'self' blob: aihblob: https://aihblob.localhost; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost aihblob: https://aihblob.localhost; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; form-action 'none'; frame-src 'none'; frame-ancestors 'none'",
      "freezePrototype": false,
      "dangerousRemoteDomainIpcAccess": [],
      "dangerousUseHttpScheme": false
    },
    "systemTray": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": true
    },
    "windows": [
      {
        "title": "AI Home",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
